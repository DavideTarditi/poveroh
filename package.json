{
  "name": "poveroh",
  "private": true,
  "workspaces": [
    "apps/api",
    "apps/web"
  ],
  "scripts": {
    "dev:backend": "npm run --prefix apps/api build && npm run --prefix apps/api start:dev",
    "dev:frontend": "npm run --prefix apps/web start:dev",
    "stage:frontend": "npm run --prefix apps/web start:stage",
    "prod:frontend": "npm run --prefix apps/web start:prod",
    "build:frontend": "npm run --prefix apps/web build",
    "test": "jest"
  },
  "dependencies": {
    "@angular/cdk": "^18.2.13",
    "@prisma/client": "^6.0.1",
    "cross-env": "^7.0.3",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "graphql": "^16.9.0",
    "graphql-http": "^1.22.3",
    "ng-apexcharts": "^1.12.0",
    "primeng": "^17.18.12",
    "prisma": "^6.0.1",
    "supertest": "^7.0.0"
  },
  "devDependencies": {
    "@babel/preset-typescript": "^7.26.0",
    "@types/jest": "^29.5.14",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "typescript": "^5.7.2"
  }
}
